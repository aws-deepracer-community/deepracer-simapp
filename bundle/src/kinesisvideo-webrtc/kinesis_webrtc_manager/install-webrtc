#!/bin/bash
INSTALL_PREFIX=$1
mkdir -p $INSTALL_PREFIX/lib
mkdir -p $INSTALL_PREFIX/include

# Copy header files
cp -r --update=none $INSTALL_PREFIX/src/src/source/*.h $INSTALL_PREFIX/include/
cp -r --update=none $INSTALL_PREFIX/src/src/include/* $INSTALL_PREFIX/include/

# Copy open-source headers
cp -r --update=none $INSTALL_PREFIX/src/open-source/include/* $INSTALL_PREFIX/include/

# Create webrtc directory structure if it doesn't exist
mkdir -p $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/webrtcclient

# Create symbolic links for the webrtc include paths
if [ -d "$INSTALL_PREFIX/include/com/amazonaws/kinesis/video/webrtcclient" ]; then
  echo "Creating symbolic links for webrtc include paths"
  # Link the Include.h file
  ln -sf $INSTALL_PREFIX/include/com/amazonaws/kinesis/video/webrtcclient/Include.h $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/webrtcclient/Include.h
  # Link the NullableDefs.h file
  ln -sf $INSTALL_PREFIX/include/com/amazonaws/kinesis/video/webrtcclient/NullableDefs.h $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/webrtcclient/NullableDefs.h
  # Link the Stats.h file
  ln -sf $INSTALL_PREFIX/include/com/amazonaws/kinesis/video/webrtcclient/Stats.h $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/webrtcclient/Stats.h
  
  # Create other necessary webrtc directories and links
  mkdir -p $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/client
  mkdir -p $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/common
  
  # Link client include
  ln -sf $INSTALL_PREFIX/include/com/amazonaws/kinesis/video/client/Include.h $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/client/Include.h
  
  # Link common include
  ln -sf $INSTALL_PREFIX/include/com/amazonaws/kinesis/video/common/Include.h $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/common/Include.h
  ln -sf $INSTALL_PREFIX/include/com/amazonaws/kinesis/video/common/jsmn.h $INSTALL_PREFIX/include/webrtc/com/amazonaws/kinesis/video/common/jsmn.h
fi

# Copy libraries (handle missing files gracefully)
if ls $INSTALL_PREFIX/src/open-source/lib/*.so 1> /dev/null 2>&1; then
    cp $INSTALL_PREFIX/src/open-source/lib/*.so $INSTALL_PREFIX/lib
fi
if ls $INSTALL_PREFIX/src/open-source/lib/*.so.1 1> /dev/null 2>&1; then
    cp $INSTALL_PREFIX/src/open-source/lib/*.so.1 $INSTALL_PREFIX/lib
fi
if ls $INSTALL_PREFIX/src/open-source/lib/*.so.15 1> /dev/null 2>&1; then
    cp $INSTALL_PREFIX/src/open-source/lib/*.so.15 $INSTALL_PREFIX/lib
fi
if ls $INSTALL_PREFIX/src/open-source/lib/*.a 1> /dev/null 2>&1; then
    cp $INSTALL_PREFIX/src/open-source/lib/*.a $INSTALL_PREFIX/lib
fi

if ls $INSTALL_PREFIX/build/*.so 1> /dev/null 2>&1; then
    cp $INSTALL_PREFIX/build/*.so $INSTALL_PREFIX/lib
fi
echo "[CMake Build] install-webrtc script executed"